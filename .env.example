# ============================================================================
#  TRAMONTANE CONFIGURATION
# ============================================================================

# ----------------------------------------------------------------------------
#  APPLICATION
# ----------------------------------------------------------------------------

ADMIN_EMAILS='["you@example.com"]'
CORS_ORIGINS='["http://localhost:5173","https://app.tropis.me"]'
DEBUG=false

# ----------------------------------------------------------------------------
#  SUPABASE (required)
# ----------------------------------------------------------------------------

SUPABASE_URL=https://your-project.supabase.co/
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# ----------------------------------------------------------------------------
#  REDIS (required for ARQ workers + rate limiting)
# ----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
#  LLM / AI (Mistral)
# ----------------------------------------------------------------------------

LLM_PROVIDER=mistral
LLM_MODEL=labs-mistral-small-creative
ANALYZER_PROVIDER=mistral
ANALYZER_MODEL=mistral-tiny-latest
MISTRAL_API_KEY=

# ----------------------------------------------------------------------------
#  TOOLS
# ----------------------------------------------------------------------------

TAVILY_API_KEY=
LEONARDO_API_KEY=
LEONARDO_WEBHOOK_SECRET=
ELEVENLABS_API_KEY=

# ----------------------------------------------------------------------------
#  ICECAST / STREAMING
# ----------------------------------------------------------------------------

ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_ADMIN_PASSWORD=change-me-admin
VITE_ICECAST_URL=http://localhost:8100/stream.mp3
