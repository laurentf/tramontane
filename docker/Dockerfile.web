# syntax=docker/dockerfile:1

# -- Dev stage ----------------------------------------------------------------
FROM node:20-slim AS dev

WORKDIR /app

COPY web/package.json web/package-lock.json ./

RUN npm ci

COPY web/ .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# -- Prod stage ---------------------------------------------------------------
FROM node:20-slim AS prod

WORKDIR /app

COPY web/package.json web/package-lock.json ./

RUN npm ci

COPY web/ .

RUN npm run build

RUN npm install -g serve

EXPOSE 3000

USER node

CMD ["serve", "-s", "dist", "-l", "3000"]
